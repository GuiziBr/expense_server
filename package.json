{
	"name": "expenses_server",
	"version": "1.0.1",
	"description": "Expenses Dashboard Server",
	"author": "",
	"private": true,
	"license": "UNLICENSED",
	"prisma": {
		"seed": "ts-node prisma/seed.ts"
	},
	"scripts": {
		"build": "nest build",
		"format": "biome format --write .",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "npx @biomejs/biome lint --write",
		"migrate": "npx prisma migrate dev",
		"docker:up": "docker compose up",
		"docker:migrate:dev": "docker compose exec server npx prisma migrate dev",
		"docker:migrate:deploy": "docker compose exec server npx prisma migrate deploy",
		"docker:seed": "docker compose exec server npx prisma db seed",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --coverage",
		"test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
		"test:e2e": "vitest run --config ./vitest.config.e2e.ts",
		"postinstall": "prisma generate"
	},
	"dependencies": {
		"@nestjs/common": "^10.0.0",
		"@nestjs/config": "^3.2.3",
		"@nestjs/core": "^10.0.0",
		"@nestjs/jwt": "^10.2.0",
		"@nestjs/platform-express": "^10.0.0",
		"@prisma/client": "^5.20.0",
		"bcrypt": "^5.1.1",
		"date-fns": "^4.1.0",
		"reflect-metadata": "^0.2.0",
		"rxjs": "^7.8.1",
		"zod": "^3.23.8",
		"zod-validation-error": "^3.4.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@faker-js/faker": "^9.0.3",
		"@nestjs/cli": "^10.0.0",
		"@nestjs/schematics": "^10.0.0",
		"@nestjs/testing": "^10.0.0",
		"@types/bcrypt": "^5.0.2",
		"@types/express": "^4.17.17",
		"@types/node": "^20.3.1",
		"@vitest/coverage-v8": "^2.1.2",
		"prisma": "^5.20.0",
		"source-map-support": "^0.5.21",
		"ts-loader": "^9.4.3",
		"ts-node": "^10.9.1",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.1.3",
		"ultracite": "^7.2.5",
		"unplugin-swc": "^1.5.1",
		"vitest": "^2.1.2"
	},
	"engines": {
		"node": ">=24"
	}
}
